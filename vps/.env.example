PANGOLIN_CONFIG_DIR=/opt/pangolin/config
DOZZLE_HOSTNAME=homeserver-vps

# Tailscale is authenticated by GitHub Actions on first deploy using TS_OAUTH_SECRET.
# Keep TS_AUTHKEY empty in this host-local file unless manually joining the tailnet.
TS_AUTHKEY=
TS_AUTH_ONCE=true
TS_EXTRA_ARGS=--advertise-tags=tag:ci
TS_HOSTNAME=homeserver-vps
TAILSCALE_STATE_DIR=./tailscale-state

# The start script auto-detects the VPS Tailscale IPv4 address when this is left empty.
DOZZLE_AGENT_BIND=127.0.0.1
